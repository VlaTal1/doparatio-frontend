<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#131A17"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/configure_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Select Habit"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/configure_empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="40dp"
        android:text="No habits found. Please open the DopaRatio app and sync your habits first."
        android:textColor="#8A9F95"
        android:textSize="14sp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/configure_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#242D29"
        android:dividerHeight="1dp" />
</LinearLayout>
